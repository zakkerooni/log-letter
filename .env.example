# =====================================================================
# Stripe — 開発時はテストキー、本番 (Cloudflare 環境変数) はライブキー
#   Test:  https://dashboard.stripe.com/test/apikeys
#   Live:  https://dashboard.stripe.com/apikeys
# =====================================================================
STRIPE_SECRET_KEY=sk_test_xxxxx

# Webhook シークレット (Stripe Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# =====================================================================
# TinaCMS Cloud (https://app.tina.io から取得)
#   - PUBLIC_TINA_CLIENT_ID: プロジェクトの Client ID
#   - TINA_TOKEN: コンテンツ書き込み用 Read/Write トークン
# =====================================================================
PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# =====================================================================
# サイト上部のお知らせバナー (空欄なら非表示)
# =====================================================================
PUBLIC_BANNER_TEXT=

# =====================================================================
# SNS（連絡先は src/copy/site.ja.json の links.companyContactUrl で管理）
# =====================================================================
PUBLIC_INSTAGRAM_URL=https://instagram.com/yourname

# =====================================================================
# Google Analytics (空欄ならタグは挿入されない)
# =====================================================================
PUBLIC_GA_ID=
