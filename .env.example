# =====================================================================
# Stripe — 開発時はテストキー、本番(Cloudflare Pages 環境変数)はライブキー
#   Test:  https://dashboard.stripe.com/test/apikeys
#   Live:  https://dashboard.stripe.com/apikeys
# =====================================================================
STRIPE_SECRET_KEY=sk_test_xxxxx

# Webhook シークレット (Stripe Dashboard → Developers → Webhooks)
# ローカルでは stripe-cli で生成、本番は Cloudflare Pages 環境変数に whsec_xxx を設定
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# =====================================================================
# サイト上部のお知らせバナー (空欄なら非表示)
# =====================================================================
PUBLIC_BANNER_TEXT=

# =====================================================================
# SNS（連絡先は src/content/site.ja.json の links.companyContactUrl で管理）
# =====================================================================
PUBLIC_INSTAGRAM_URL=https://instagram.com/yourname

# =====================================================================
# Google Analytics (空欄ならタグは挿入されない)
# =====================================================================
PUBLIC_GA_ID=
