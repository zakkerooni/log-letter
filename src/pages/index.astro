---
import Layout from '../layouts/Layout.astro';
import Stripe from 'stripe';
const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
const products = await stripe.products.list({ active: true, expand: ['data.default_price'] });
---

<Layout title="Postcard Library">
	<main class="max-w-[1400px] mx-auto px-6 py-20">
		<header class="mb-16">
			<h2 class="text-[11px] tracking-[0.4em] uppercase text-gray-400 mb-3 font-light">New Arrivals</h2>
			<div class="w-12 h-[1px] bg-black"></div>
		</header>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
			{products.data.map((product) => (
				<div class="flex flex-col h-full">
					<div class="overflow-hidden bg-[#f2f2f2] aspect-[3/4] mb-8 group">
						<img src={product.images[0]} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out" />
					</div>
					<div class="flex-grow space-y-3">
						<div class="flex justify-between items-start gap-4">
							<div class="min-h-[64px]">
								<p class="text-[10px] text-gray-400 uppercase tracking-[0.2em] mb-2 font-light">
									{product.metadata.creator || 'MiKS Collective'}
								</p>
								<h3 class="text-[13px] tracking-[0.1em] font-normal leading-relaxed">{product.name}</h3>
							</div>
							<span class="text-[12px] font-light pt-1">
								¥{product.default_price ? product.default_price.unit_amount.toLocaleString() : '---'}
							</span>
						</div>
					</div>
					<form action="/api/checkout" method="POST" class="mt-8">
						<input type="hidden" name="priceId" value={product.default_price?.id} />
						<button type="submit" class="w-full border border-black py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-black hover:text-white transition-all duration-500">
							Add to Cart
						</button>
					</form>
				</div>
			))}
		</div>
	</main>
</Layout>