---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import AboutBlock from '../components/AboutBlock.astro';
import ProductCard from '../components/ProductCard.astro';
import Stripe from 'stripe';

const site = Astro.locals.site;
const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
const products = await stripe.products.list({ active: true, expand: ['data.default_price'] });

// Also get inactive products for "sold out" display
const allProducts = await stripe.products.list({ expand: ['data.default_price'] });
const soldOutProducts = allProducts.data.filter(p => !p.active);

// Picks: featured を先頭に、残りは元の順序で 6 件まで
const isFeatured = (p) => String(p.metadata?.featured || '').toLowerCase() === 'true';
const featured = products.data.filter(isFeatured);
const rest = products.data.filter((p) => !isFeatured(p));
const picks = [...featured, ...rest].slice(0, 6);

// Collect unique creators / series for filter
const creators = [...new Set(products.data.map(p => p.metadata?.creator || 'POST'))];
const seriesList = [...new Set(products.data.map(p => p.metadata?.series).filter(Boolean))];

// Build product data for search
const searchData = products.data.map(p => ({
  id: p.id,
  name: p.name,
  creator: p.metadata?.creator || 'POST',
  image: p.images?.[0] || '',
  price: p.default_price?.unit_amount ?? 0,
}));
---

<Layout title="Home">
  <!-- Search data for JS -->
  <script define:vars={{ searchData }}>
    window.__products = searchData;
  </script>

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Store",
    "name": site.meta.storeJsonLdName,
    "description": site.meta.storeJsonLdDescription,
    "url": Astro.url.origin,
    "image": `${Astro.url.origin}/images/ogp.jpg`,
    "address": { "@type": "PostalAddress", "addressLocality": site.meta.addressLocality, "addressCountry": site.meta.addressCountry }
  })} />

  <!-- Hero -->
  {(() => {
    const heroImage = site.home.heroImage || '/images/hero.jpg';
    const heroHeight = Number(site.home.heroHeight) > 0 ? `${site.home.heroHeight}px` : '75vh';
    return (
      <section class="hero" style={`height: ${heroHeight};`}>
        <img
          src={heroImage}
          alt={site.meta.siteSuffix}
          class="hero-img"
          onerror="this.style.display='none'"
        />
        <div class="hero-overlay">
          <h1 class="hero-title">{site.home.heroTitle}</h1>
          <p class="hero-sub">{site.home.heroSub}</p>
        </div>
      </section>
    );
  })()}

  <!-- Concept -->
  <AboutBlock />

  <!-- Picks Carousel -->
  <section style="padding: 0 0 80px;">
    <div style="text-align: center; padding: 0 40px 48px;">
      <span class="section-title-sm">{site.home.picksLabelSm}</span>
      <h2 class="section-title" style="margin-bottom: 0;">{site.home.picksHeading}</h2>
    </div>
    <div class="carousel-section">
      <button class="carousel-nav carousel-prev" aria-label="Previous" data-carousel-prev>
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      <div class="carousel-track" data-carousel-track>
        {picks.map((product) => <ProductCard product={product} />)}
      </div>
      <button class="carousel-nav carousel-next" aria-label="Next" data-carousel-next>
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M9 18l6-6-6-6" /></svg>
      </button>
    </div>
  </section>

  <!-- Archive Grid -->
  <section id="archive" class="products-section" style="border-top: 1px solid var(--border);">
    <div style="text-align: center; margin-bottom: 32px;">
      <span class="section-title-sm">{products.data.length} {site.home.archiveRecordsSuffix}</span>
      <h2 class="section-title" style="margin-bottom: 0;">{site.home.archiveHeading}</h2>
    </div>

    <!-- Filter (creator) -->
    {creators.length > 1 && (
      <div class="filter-bar" data-filter-bar="creator">
        <button class="filter-btn active" data-filter="all">{site.home.filterAll}</button>
        {creators.map(c => (
          <button class="filter-btn" data-filter={c}>{c}</button>
        ))}
      </div>
    )}

    <!-- Filter (series) -->
    {seriesList.length > 1 && (
      <div class="filter-bar" data-filter-bar="series">
        <button class="filter-btn active" data-series-filter="all">{site.home.filterAll}</button>
        {seriesList.map(s => (
          <button class="filter-btn" data-series-filter={s}>{s}</button>
        ))}
      </div>
    )}

    <div class="product-grid" id="product-grid">
      {products.data.map((product) => <ProductCard product={product} />)}
    </div>

    <!-- Sold out products -->
    {soldOutProducts.length > 0 && (
      <div class="product-grid" style="margin-top: 40px;">
        {soldOutProducts.map((product) => {
          const image = product.images?.[0] || '';
          const creator = product.metadata?.creator || 'POST';
          return (
            <article class="product-card" style="opacity: 0.6; pointer-events: none;">
              <div class="product-card-img">
                <span class="sold-out-label">{site.product.soldOut}</span>
                <img src={image} alt={product.name} loading="lazy" />
              </div>
              <p class="product-card-creator">{creator}</p>
              <p class="product-card-name">{product.name}</p>
              <p class="product-card-price" style="text-decoration: line-through;">¥{(product.default_price?.unit_amount ?? 0).toLocaleString()}</p>
            </article>
          );
        })}
      </div>
    )}
  </section>
</Layout>

<script>
  // Carousel
  const track = document.querySelector('[data-carousel-track]');
  document.querySelector('[data-carousel-prev]')?.addEventListener('click', () => {
    track?.scrollBy({ left: -260, behavior: 'smooth' });
  });
  document.querySelector('[data-carousel-next]')?.addEventListener('click', () => {
    track?.scrollBy({ left: 260, behavior: 'smooth' });
  });

  // Filter — creator と series の AND で絞り込み
  let activeCreator = 'all';
  let activeSeries = 'all';
  function applyFilters() {
    document.querySelectorAll('#product-grid .product-card').forEach(card => {
      const c = card.dataset.creator || '';
      const s = card.dataset.series || '';
      const matchCreator = activeCreator === 'all' || c === activeCreator;
      const matchSeries = activeSeries === 'all' || s === activeSeries;
      card.style.display = matchCreator && matchSeries ? '' : 'none';
    });
  }
  document.querySelectorAll('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCreator = btn.dataset.filter;
      document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
  document.querySelectorAll('[data-series-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      activeSeries = btn.dataset.seriesFilter;
      document.querySelectorAll('[data-series-filter]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
</script>
