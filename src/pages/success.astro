---
import Layout from '../layouts/Layout.astro'; // もしLayoutファイルがあれば
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<title>Thank you | MiKS</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300&family=Noto+Serif+JP:wght@300&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#fdfdfd] text-[#1a1a1a] font-['Inter'] antialiased flex items-center justify-center min-h-screen">
		<div class="text-center space-y-8 animate-fade-in">
			<h1 class="text-[11px] tracking-[0.4em] uppercase text-gray-400">Order Completed</h1>
			<div class="space-y-4">
				<p class="text-xl font-light tracking-widest">ご購入ありがとうございました。</p>
				<p class="text-[12px] text-gray-500 leading-relaxed font-light">
					ポストカードは1週間以内に発送いたします。<br>
					手元に届くまでの時間も、どうぞお楽しみください。
				</p>
			</div>
			<div class="pt-8">
				<a href="/" class="text-[10px] tracking-[0.2em] uppercase border-b border-black pb-1 hover:text-gray-400 hover:border-gray-400 transition-all">
					Back to Library
				</a>
			</div>
		</div>
	</body>
</html>
