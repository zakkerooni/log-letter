---
import Layout from '../layouts/Layout.astro';

const site = Astro.locals.site;
---

<Layout title="Thank you">
  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 80px 40px;">
    <div style="max-width: 640px;">
      <span class="section-title-sm">{site.success.smallLabel}</span>
      <div class="about-text" style="margin-top: 32px;">
        {site.success.paragraphs.map((p) => <p set:html={p}></p>)}
        <p style="font-size: 11px; color: var(--muted); letter-spacing: 0.2em; font-family: var(--font-body);">
          {site.success.subNote}
        </p>
      </div>
      <div style="margin-top: 48px;">
        <a href="/" class="product-card-btn" style="width: auto; display: inline-block; padding: 14px 60px;">
          {site.success.backToHome}
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // 決済完了後、カートをクリア
  localStorage.removeItem('post-cart');
</script>
