---
import Layout from '../layouts/Layout.astro';
import AboutBlock from '../components/AboutBlock.astro';
---

<Layout title="About">
  <section class="max-w-[1400px] mx-auto px-8 py-32 min-h-[70vh] flex flex-col justify-center">
    <AboutBlock />
    <div class="mt-24 text-center">
      <a
        href="/#archive"
        class="text-[10px] tracking-[0.4em] uppercase border border-[#1c2333] text-[#1c2333] px-14 py-4 hover:bg-[#1c2333] hover:text-white transition-all duration-500"
      >
        Back to Archive
      </a>
    </div>
  </section>
</Layout>
