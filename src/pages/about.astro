---
import Layout from '../layouts/Layout.astro';

const site = Astro.locals.site;

const paragraphs = site.about.body
  ? site.about.body.split(/\n{2,}/)
  : (site.about.paragraphs ?? []);
---

<Layout title={site.header.navAbout}>
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    {site.header.navAbout}
  </div>

  <section class="about-section" style="padding-top: 40px; padding-bottom: 60px;">
    <div style="margin-bottom: 48px;">
      <span class="section-title-sm">{site.about.smallLabel}</span>
      <h2 class="section-title" style="margin-bottom: 0;">{site.about.heading}</h2>
    </div>
    <div class="about-text">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
    {site.about.signature && (
      <p class="about-signature">{site.about.signature}</p>
    )}
  </section>

  <!-- Concept images -->
  <section style="max-width: 1000px; margin: 0 auto; padding: 0 40px 100px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div style="aspect-ratio: 4/5; background: var(--card-bg); overflow: hidden;">
        <img src="/images/about-1.jpg" alt="Kanazawa" style="width:100%; height:100%; object-fit:cover;"
          onerror="this.style.display='none'" />
      </div>
      <div style="aspect-ratio: 4/5; background: var(--card-bg); overflow: hidden;">
        <img src="/images/about-2.jpg" alt="Postcards" style="width:100%; height:100%; object-fit:cover;"
          onerror="this.style.display='none'" />
      </div>
    </div>
  </section>

  <div style="text-align: center; padding-bottom: 80px;">
    <a href="/#archive" class="product-card-btn" style="width: auto; display: inline-block; padding: 14px 60px;">
      {site.about.backToArchive}
    </a>
  </div>
</Layout>
