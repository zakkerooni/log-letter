---
const { title } = Astro.props;
const faviconUrl = import.meta.env.PUBLIC_FAVICON_URL || "/favicon.svg";
---

<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | MiKS - Record of a moment</title>
    <meta name="description" content="金沢、ポストカード・ライブラリー、ある瞬間の記録を、手に取れる形へ。" />
    <meta property="og:title" content={`${title} | MiKS`} />
    <meta property="og:description" content="Record of a moment. クリエイターの視点を届けるポストカードショップ。" />
    <meta property="og:image" content="/images/ogp.jpg" /> <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=Noto+Serif+JP:wght@300&display=swap" rel="stylesheet">
</head>
	<body class="bg-[#fdfdfd] text-[#1a1a1a] font-['Inter'] antialiased">
		<nav class="fixed top-0 left-0 w-full px-6 py-8 flex justify-between items-center z-50 bg-[#fdfdfd]/40 backdrop-blur-sm transition-all duration-500 hover:bg-[#fdfdfd]/90">
			<a href="/" class="flex items-center group">
				<img src="/images/logo.png" alt="MiKS" class="h-4 w-auto object-contain" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');" />
				<span class="text-lg tracking-[0.3em] font-light hidden">MiKS</span>
			</a>
			<div class="text-[9px] tracking-[0.4em] uppercase text-gray-400">
				<a href="#archive" class="hover:text-black transition-colors">Archive</a>
			</div>
		</nav>

		<slot />

		<footer class="mt-40 border-t border-[#e5e5e5] px-6 py-24 bg-[#f9f9f9]">
			<div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between gap-12 text-[9px] tracking-[0.3em] text-gray-400 uppercase font-light">
				<div>
					<p class="text-black mb-4 font-normal tracking-[0.4em]">MiKS inc. / Kanazawa</p>
					<p>© 2026 Record of a moment</p>
				</div>
				<div class="flex gap-12">
					<a href="#" class="hover:text-black transition-colors">Instagram</a>
					<a href="mailto:info@miks-inc.com" class="hover:text-black transition-colors">Contact</a>
				</div>
			</div>
		</footer>
	</body>
</html>