---
import Layout from '../../layouts/Layout.astro';
import site from '../../content/site.ja.json';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('legal', 'shipping');
const { Content } = await render(entry);
---

<Layout title={site.legal.shippingTitle}>
  <div class="breadcrumb">
    <a href="/">Home</a><span>/</span>{site.legal.shippingTitle}
  </div>
  <div class="legal-page">
    <h1>{site.legal.shippingTitle}</h1>
    <Content />
  </div>
</Layout>
