---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Stripe from 'stripe';
import site from '../../content/site.ja.json';

const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
const { id } = Astro.params;

let product;
try {
  product = await stripe.products.retrieve(id, { expand: ['default_price'] });
} catch {
  return Astro.redirect('/404');
}
if (!product || !product.active) {
  return Astro.redirect('/404');
}

const price = product.default_price;
const amount = price?.unit_amount ?? 0;
const images = product.images?.length ? product.images : ['https://placehold.jp/24/eeeeee/999999/800x800.png?text=POST'];
const creator = product.metadata?.creator || 'POST';

// Related products
const allProducts = await stripe.products.list({ active: true, expand: ['data.default_price'] });
const related = allProducts.data.filter(p => p.id !== product.id).slice(0, 4);

// Search data
const searchData = allProducts.data.map(p => ({
  id: p.id, name: p.name,
  creator: p.metadata?.creator || 'POST',
  image: p.images?.[0] || '', price: p.default_price?.unit_amount ?? 0,
}));
---

<Layout title={product.name}>
  <script define:vars={{ searchData }}>
    window.__products = searchData;
  </script>

  <!-- JSON-LD Product -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.name,
    "image": images,
    "description": product.description || '',
    "brand": { "@type": "Brand", "name": "POST" },
    "offers": {
      "@type": "Offer",
      "price": amount,
      "priceCurrency": "JPY",
      "availability": "https://schema.org/InStock",
      "url": `${Astro.url.origin}/product/${product.id}`
    }
  })} />

  <div class="breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/#archive">Archive</a>
    <span>/</span>
    {product.name}
  </div>

  <div class="detail-page">
    <div class="detail-images">
      <div class="detail-main-img zooming" id="main-img-container">
        <img src={images[0]} alt={product.name} id="main-img" />
        {images.length > 1 && (
          <Fragment>
            <button class="detail-img-nav detail-img-prev" data-img-prev aria-label="Previous image">
              <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6" /></svg>
            </button>
            <button class="detail-img-nav detail-img-next" data-img-next aria-label="Next image">
              <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" /></svg>
            </button>
          </Fragment>
        )}
      </div>
      {images.length > 1 && (
        <div class="detail-thumbs" id="thumbs">
          {images.map((img, i) => (
            <div class={`detail-thumb ${i === 0 ? 'active' : ''}`} data-thumb-idx={i}>
              <img src={img} alt="" />
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="detail-info">
      <p class="detail-creator">{creator}</p>
      <h1 class="detail-name">{product.name}</h1>
      <p class="detail-price">¥{amount.toLocaleString()} <span style="font-size: 11px; color: var(--muted); margin-left: 8px;">{site.product.taxNote}</span></p>

      <!-- 信頼バッジ -->
      <div class="trust-row">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-6 9 6v9a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 21V11h6v10"/></svg>
          <span>{site.product.trustShip}</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          <span>{site.product.trustPay}</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>{site.product.trustSsl}</span>
        </div>
      </div>

      <!-- 在庫表示 -->
      <p class="stock-status">
        <span class="stock-dot"></span>
        <strong>{site.product.stockLabel}</strong>
        <span style="color: var(--muted); margin-left: 8px;">{site.product.stockNote}</span>
      </p>

      <!-- 配送目安 -->
      <p class="delivery-info" set:html={site.product.deliveryNote}></p>

      {product.description && (
        <p class="detail-desc">{product.description}</p>
      )}

      <!-- 数量 -->
      <div class="qty-selector">
        <label>{site.product.qtyLabel}</label>
        <div class="qty-control">
          <button type="button" data-qty-dec aria-label="減らす">−</button>
          <input type="number" id="qty-input" value="1" min="1" max="10" />
          <button type="button" data-qty-inc aria-label="増やす">+</button>
        </div>
      </div>

      <!-- 購入ボタン -->
      <button
        type="button"
        class="detail-buy-btn buy-cart"
        data-add-cart
        data-product-id={product.id}
        data-price-id={price?.id}
        data-name={product.name}
        data-creator={creator}
        data-image={images[0]}
        data-price={amount}
      >
        {site.product.addToCart}
      </button>
      <button
        type="button"
        class="detail-buy-btn buy-now"
        data-buy-now
        data-product-id={product.id}
        data-price-id={price?.id}
        data-name={product.name}
        data-creator={creator}
        data-image={images[0]}
        data-price={amount}
      >
        {site.product.buyNow}
      </button>

      <div class="detail-meta">
        <p>{site.product.metaSize}</p>
        <p>{site.product.metaPrint}</p>
        <p>{site.product.metaShip}</p>
        <p>{site.product.metaFee}</p>
      </div>
    </div>
  </div>

  <!-- Related -->
  {related.length > 0 && (
    <section class="products-section related-section" style="border-top: 1px solid var(--border);">
      <div style="text-align: center; margin-bottom: 48px;">
        <h2 class="section-title" style="margin-bottom: 0;">{site.product.relatedHeading}</h2>
      </div>
      <div class="product-grid related-grid">
        {related.map((p) => <ProductCard product={p} />)}
      </div>
    </section>
  )}
</Layout>

<script define:vars={{ images }}>
  window.__detailImages = images;
</script>
<script>
  const imgs = window.__detailImages || [];
  let currentIdx = 0;
  const mainImg = document.getElementById('main-img');
  const container = document.getElementById('main-img-container');
  const thumbs = document.querySelectorAll('[data-thumb-idx]');

  function setImage(idx) {
    if (!imgs[idx] || !mainImg) return;
    currentIdx = idx;
    mainImg.src = imgs[idx];
    thumbs.forEach((t, i) => t.classList.toggle('active', i === idx));
  }

  // Arrow navigation
  document.querySelector('[data-img-prev]')?.addEventListener('click', () => {
    setImage((currentIdx - 1 + imgs.length) % imgs.length);
  });
  document.querySelector('[data-img-next]')?.addEventListener('click', () => {
    setImage((currentIdx + 1) % imgs.length);
  });

  // Thumb clicks
  thumbs.forEach(t => {
    t.addEventListener('click', () => setImage(parseInt(t.dataset.thumbIdx)));
  });

  // Zoom on hover (follow cursor)
  if (container) {
    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width * 100);
      const y = ((e.clientY - rect.top) / rect.height * 100);
      container.style.setProperty('--zoom-x', x + '%');
      container.style.setProperty('--zoom-y', y + '%');
    });
  }

  // Quantity selector
  const qtyInput = document.getElementById('qty-input');
  document.querySelector('[data-qty-dec]')?.addEventListener('click', () => {
    if (!qtyInput) return;
    qtyInput.value = Math.max(1, parseInt(qtyInput.value) - 1);
  });
  document.querySelector('[data-qty-inc]')?.addEventListener('click', () => {
    if (!qtyInput) return;
    qtyInput.value = Math.min(10, parseInt(qtyInput.value) + 1);
  });

  // Apply quantity to add-cart button + buy-now
  function getQty() { return Math.max(1, Math.min(10, parseInt(qtyInput?.value || '1'))); }

  document.querySelector('.buy-cart')?.addEventListener('click', (e) => {
    // override: add multiple
    e.preventDefault();
    e.stopImmediatePropagation();
    const btn = e.currentTarget;
    const qty = getQty();
    const cart = JSON.parse(localStorage.getItem('post-cart') || '[]');
    const existing = cart.find(c => c.productId === btn.dataset.productId);
    if (existing) {
      existing.qty = Math.min(10, existing.qty + qty);
    } else {
      cart.push({
        productId: btn.dataset.productId,
        priceId: btn.dataset.priceId,
        name: btn.dataset.name,
        creator: btn.dataset.creator,
        image: btn.dataset.image,
        price: parseInt(btn.dataset.price),
        qty: qty,
      });
    }
    localStorage.setItem('post-cart', JSON.stringify(cart));
    // trigger badge + toast via events
    document.dispatchEvent(new CustomEvent('cart-updated', { detail: { msg: `${btn.dataset.name} を ${qty}点 カートに追加しました` } }));
  }, true);

  // Buy now: 直接Stripe決済
  document.querySelector('[data-buy-now]')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    const qty = getQty();
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/api/checkout';
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'cartData';
    input.value = JSON.stringify([{ priceId: btn.dataset.priceId, qty }]);
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  });
</script>
