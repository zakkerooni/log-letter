---
const { product } = Astro.props;
const price = product.default_price;
const amount = price?.unit_amount ?? 0;
const image = product.images?.[0] || 'https://placehold.jp/24/eeeeee/999999/800x800.png?text=POST';
const creator = product.metadata?.creator || 'POST';
---

<article class="product-card">
  <a href={`/product/${product.id}`}>
    <div class="product-card-img">
      <img
        src={image}
        alt={product.name}
        loading="lazy"
      />
    </div>
    <p class="product-card-creator">{creator}</p>
    <p class="product-card-name">{product.name}</p>
    <p class="product-card-price">¥{amount.toLocaleString()}</p>
  </a>
  <form action="/api/checkout" method="POST">
    <input type="hidden" name="priceId" value={price?.id} />
    <button type="submit" class="product-card-btn">
      Add to Cart
    </button>
  </form>
</article>
