---
import site from '../copy/site.json';
const { compact = false } = Astro.props;
---

<div class={`about-section ${compact ? 'compact' : ''}`}>
  <div style="margin-bottom: 32px;">
    <span class="section-title-sm">{site.concept.smallLabel}</span>
    <h2 class="section-title" style="margin-bottom: 0;">{site.concept.heading}</h2>
  </div>
  <div class="about-text">
    {site.concept.paragraphs.map((p) => <p>{p}</p>)}
  </div>
</div>
